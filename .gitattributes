# Enforce LF line endings for all text files
* text=auto eol=lf

# Windows scripts — keep CRLF so they work natively on Windows
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.gz   binary
